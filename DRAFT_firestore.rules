rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == 'dilshodallaberdiyev57@gmail.com'
      );
    }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidFlora(data) {
      return data.keys().hasAll(['name', 'description']) &&
             data.keys().size() >= 2 && data.keys().size() <= 6 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.description is string && data.description.size() > 0 && data.description.size() <= 5000 &&
             (!('imagePrompt' in data) || (data.imagePrompt is string && data.imagePrompt.size() <= 1000)) &&
             (!('imageUrl' in data) || (data.imageUrl is string && data.imageUrl.size() <= 2000)) &&
             (!('fact' in data) || (data.fact is string && data.fact.size() <= 2000));
    }

    function isValidFauna(data) {
      return data.keys().hasAll(['name', 'description']) &&
             data.keys().size() >= 2 && data.keys().size() <= 6 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.description is string && data.description.size() > 0 && data.description.size() <= 5000 &&
             (!('imagePrompt' in data) || (data.imagePrompt is string && data.imagePrompt.size() <= 1000)) &&
             (!('imageUrl' in data) || (data.imageUrl is string && data.imageUrl.size() <= 2000)) &&
             (!('fact' in data) || (data.fact is string && data.fact.size() <= 2000));
    }

    function isValidHistory(data) {
      return data.keys().hasAll(['title', 'description']) &&
             data.keys().size() >= 2 && data.keys().size() <= 5 &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.description is string && data.description.size() > 0 && data.description.size() <= 10000 &&
             (!('period' in data) || (data.period is string && data.period.size() <= 100)) &&
             (!('imagePrompt' in data) || (data.imagePrompt is string && data.imagePrompt.size() <= 1000)) &&
             (!('imageUrl' in data) || (data.imageUrl is string && data.imageUrl.size() <= 2000));
    }

    function isValidFeedback(data) {
      return data.keys().hasAll(['name', 'email', 'message', 'status']) &&
             data.keys().size() == 5 && // Including createdAt if generated by client or server
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.email is string && data.email.size() > 0 && data.email.size() <= 320 &&
             data.message is string && data.message.size() > 0 && data.message.size() <= 5000 &&
             data.status in ['pending', 'reviewed', 'resolved'] &&
             data.createdAt is timestamp;
    }

    // --- Collection Rules ---

    match /flora/{id} {
      allow read: if true;
      allow create: if isAdmin() && isValidFlora(incoming());
      allow update: if isAdmin() && isValidFlora(incoming());
      allow delete: if isAdmin();
    }

    match /fauna/{id} {
      allow read: if true;
      allow create: if isAdmin() && isValidFauna(incoming());
      allow update: if isAdmin() && isValidFauna(incoming());
      allow delete: if isAdmin();
    }

    match /history/{id} {
      allow read: if true;
      allow create: if isAdmin() && isValidHistory(incoming());
      allow update: if isAdmin() && isValidHistory(incoming());
      allow delete: if isAdmin();
    }

    match /feedback/{id} {
      allow create: if isValidFeedback(incoming()) && incoming().status == 'pending' && incoming().createdAt == request.time;
      allow read, list, update, delete: if isAdmin();
    }

    match /admins/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow write: if false; // Only manageable via console or specialized tool
    }
  }
}
